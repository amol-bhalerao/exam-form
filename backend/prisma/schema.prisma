generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "linux-musl", "debian-openssl-1.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  ACTIVE
  PENDING
  DISABLED
}

enum InstituteStatus {
  APPROVED
  PENDING
  REJECTED
  DISABLED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  INSTITUTE_VERIFIED
  BOARD_APPROVED
  REJECTED_BY_INSTITUTE
  REJECTED_BY_BOARD
}

enum CandidateType {
  REGULAR
  REPEATER
  ATKT
  BACKLOG
  IMPROVEMENT
  PRIVATE
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)
  users     User[]
  createdAt DateTime @default(now())

  @@map("roles")
}

model Institute {
  id            Int             @id @default(autoincrement())
  collegeNo     String          @db.VarChar(20)
  udiseNo       String          @db.VarChar(20)
  name          String          @db.VarChar(200)
  code          String?         @unique @db.VarChar(50)
  address       String?         @db.Text
  district      String?         @db.VarChar(100)
  taluka        String?         @db.VarChar(100)
  city          String?         @db.VarChar(100)
  pincode       String?         @db.VarChar(10)
  contactPerson String?         @db.VarChar(100)
  contactEmail  String?         @db.VarChar(150)
  contactMobile String?         @db.VarChar(15)
  status              InstituteStatus @default(PENDING)
  acceptingApplications Boolean        @default(true)
  examApplicationLimit Int?            @default(100)
  createdAt           DateTime       @default(now())

  users        User[]
  students     Student[]
  applications ExamApplication[]
  teachers     Teacher[]
  instituteStreamSubjects InstituteStreamSubject[]
  instituteInvites InstituteInvite[]
  examCapacities InstituteExamCapacity[]

  @@index([status])
  @@map("institutes")
}

model User {
  id           Int        @id @default(autoincrement())
  roleId       Int
  instituteId  Int?
  username     String     @unique @db.VarChar(100)
  passwordHash String     @db.VarChar(255)
  email        String?    @db.VarChar(150)
  mobile       String?    @db.VarChar(15)
  status       UserStatus @default(PENDING)
  googleId     String?    @unique @db.VarChar(200)
  authProvider String?    @db.VarChar(20)
  createdAt    DateTime   @default(now())

  role      Role      @relation(fields: [roleId], references: [id])
  institute Institute? @relation(fields: [instituteId], references: [id])
  instituteInvites InstituteInvite[]
  refreshTokens RefreshToken[]

  examsCreated Exam[] @relation("ExamCreatedBy")
  newsCreated News[] @relation("NewsCreatedBy")
  studentProfile Student?

  auditLogs AuditLog[]
  statusEvents StatusHistory[] @relation("StatusActor")

  @@index([roleId])
  @@index([instituteId])
  @@map("users")
}

model InstituteInvite {
  id         Int      @id @default(autoincrement())
  instituteId Int
  userId     Int?
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  usedAt     DateTime?

  institute Institute @relation(fields: [instituteId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])

  @@index([instituteId])
  @@map("institute_invites")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  userId     Int
  tokenHash  String   @db.VarChar(255)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

model Stream {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  exams Exam[]
  streamSubjects StreamSubject[]
  instituteStreamSubjects InstituteStreamSubject[]

  @@map("streams")
}

model Subject {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(150)
  code String @unique @db.VarChar(20)
  category String @db.VarChar(30)

  applicationSubjects ExamApplicationSubject[]
  streamSubjects StreamSubject[]
  instituteStreamSubjects InstituteStreamSubject[]

  @@index([name])
  @@map("subjects")
}

model Exam {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(150)
  academicYear    String   @db.VarChar(20)
  session         String   @db.VarChar(30) // FEB-MAR / JUL-AUG
  streamId        Int
  applicationOpen DateTime
  applicationClose DateTime
  lateFeeClose    DateTime?
  instructions    String?  @db.Text
  createdByUserId Int
  createdAt       DateTime @default(now())

  stream Stream @relation(fields: [streamId], references: [id])
  createdBy User @relation("ExamCreatedBy", fields: [createdByUserId], references: [id])
  applications ExamApplication[]
  instituteCapacities InstituteExamCapacity[]

  @@index([streamId])
  @@index([applicationOpen, applicationClose])
  @@map("exams")
}

model InstituteExamCapacity {
  id           Int      @id @default(autoincrement())
  instituteId  Int
  examId       Int
  totalStudents Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  institute Institute @relation(fields: [instituteId], references: [id])
  exam      Exam      @relation(fields: [examId], references: [id])

  @@unique([instituteId, examId])
  @@index([instituteId])
  @@index([examId])
  @@map("institute_exam_capacities")
}

model Student {
  id           Int      @id @default(autoincrement())
  instituteId  Int
  userId       Int?     @unique
  firstName    String?  @db.VarChar(100)
  middleName   String?  @db.VarChar(100)
  lastName     String?  @db.VarChar(100)
  motherName   String?  @db.VarChar(100)
  dob          DateTime?
  gender       String?  @db.VarChar(20)
  aadhaar      String?  @db.VarChar(20)
  apaarId      String?  @db.VarChar(20)
  address      String?  @db.Text
  district     String?  @db.VarChar(100)
  taluka       String?  @db.VarChar(100)
  village      String?  @db.VarChar(100)
  pinCode      String?  @db.VarChar(10)
  mobile       String?  @db.VarChar(15)

  // PDF coded fields (stored as string codes but validated via master data in UI)
  streamCode        String? @db.VarChar(10)
  minorityReligionCode String? @db.VarChar(10)
  categoryCode      String? @db.VarChar(10)
  divyangCode       String? @db.VarChar(10)
  mediumCode        String? @db.VarChar(10)

  createdAt DateTime @default(now())

  institute Institute @relation(fields: [instituteId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])
  previousExams PreviousExam[]
  feeReimbursement FeeReimbursement?
  applications ExamApplication[]

  @@index([instituteId])
  @@index([lastName, firstName])
  @@map("students")
}

model ExamApplication {
  id            Int               @id @default(autoincrement())
  instituteId   Int
  studentId     Int
  examId        Int
  applicationNo String            @unique @db.VarChar(50)
  status        ApplicationStatus @default(DRAFT)
  candidateType CandidateType

  // PDF header fields
  indexNo       String? @db.VarChar(50)
  udiseNo       String? @db.VarChar(50)
  studentSaralId String? @db.VarChar(50)
  applSrNo      String? @db.VarChar(50)
  centreNo      String? @db.VarChar(50)

  // PDF section 14 coded options
  typeA         String? @db.VarChar(10) // Fresh/Repeater
  typeB         String? @db.VarChar(10) // Regular/Private/Isolated/Class Improvement
  typeC         String? @db.VarChar(10) // Exempted/Non Exempted
  typeD         String? @db.VarChar(10) // Agriculture/Bifocal/IT/General/Home Science
  isForeigner   Boolean @default(false)

  totalExemptionsClaimed Int @default(0)

  // Private candidate enrollment
  enrollmentCertMonth String? @db.VarChar(10)
  enrollmentCertYear  Int?
  enrollmentNo        String? @db.VarChar(50)

  // Repeaters last exam seat info
  lastExamMonth String? @db.VarChar(10)
  lastExamYear  Int?
  lastExamSeatNo String? @db.VarChar(50)

  sscPassedFromMaharashtra Boolean?
  eligibilityCertIssued Boolean?
  eligibilityCertNo     String? @db.VarChar(50)

  instituteVerificationRemark String? @db.Text
  boardRemark                String? @db.Text

  submittedAt DateTime?
  instituteVerifiedAt DateTime?
  boardApprovedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  institute Institute @relation(fields: [instituteId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])
  exam      Exam      @relation(fields: [examId], references: [id])

  subjects  ExamApplicationSubject[]
  exemptedSubjects ExemptedSubjectInfo[]
  documents ExamApplicationDocument[]
  fees      Payment[]
  statusHistory StatusHistory[]

  @@index([instituteId, status])
  @@index([examId, status])
  @@index([studentId])
  @@map("exam_applications")
}

model ExamApplicationSubject {
  id              Int     @id @default(autoincrement())
  applicationId   Int
  subjectId       Int
  langOfAnsCode   String? @db.VarChar(10)
  isExemptedClaim Boolean @default(false)

  application ExamApplication @relation(fields: [applicationId], references: [id])
  subject     Subject         @relation(fields: [subjectId], references: [id])

  @@unique([applicationId, subjectId])
  @@index([applicationId])
  @@map("exam_application_subjects")
}

model ExemptedSubjectInfo {
  id            Int      @id @default(autoincrement())
  applicationId Int
  subjectName   String?  @db.VarChar(150)
  subjectCode   String?  @db.VarChar(20)
  seatNo        String?  @db.VarChar(50)
  month         String?  @db.VarChar(10) // Feb/Jul
  year          Int?
  marksObt      String?  @db.VarChar(20)

  application ExamApplication @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@map("exempted_subject_info")
}

model PreviousExam {
  id        Int    @id @default(autoincrement())
  studentId Int
  examType  String @db.VarChar(10) // SSC / XI / HSC
  seatNo    String? @db.VarChar(50)
  month     String? @db.VarChar(10)
  year      Int?
  percentage String? @db.VarChar(10) // Store as string to handle decimal values
  boardOrCollegeName String? @db.VarChar(200)

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("previous_exams")
}

model FeeReimbursement {
  id                    Int    @id @default(autoincrement())
  studentId             Int    @unique
  revenueCircleAndVillage String? @db.VarChar(200)
  accountNo             String? @db.VarChar(30)
  ifscCode              String? @db.VarChar(15)
  accountHolder         String? @db.VarChar(100)
  accountHolderRelation String? @db.VarChar(20)

  student Student @relation(fields: [studentId], references: [id])

  @@map("fee_reimbursement")
}

model ExamApplicationDocument {
  id            Int      @id @default(autoincrement())
  applicationId Int
  type          String   @db.VarChar(50)
  fileName      String   @db.VarChar(255)
  mimeType      String   @db.VarChar(100)
  filePath      String   @db.VarChar(500)
  uploadedAt    DateTime @default(now())
  verifiedAt    DateTime?
  verifiedByUserId Int?

  application ExamApplication @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@map("exam_application_documents")
}

model Payment {
  id            Int      @id @default(autoincrement())
  applicationId Int
  amountPaise   Int
  method        String?  @db.VarChar(30)
  referenceNo   String?  @db.VarChar(100)
  receivedAt    DateTime @default(now())
  receivedByUserId Int?

  application ExamApplication @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@map("payments")
}

model StatusHistory {
  id            Int               @id @default(autoincrement())
  applicationId Int
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  remark        String?           @db.Text
  actorUserId   Int
  createdAt     DateTime          @default(now())

  application ExamApplication @relation(fields: [applicationId], references: [id])
  actorUser   User            @relation("StatusActor", fields: [actorUserId], references: [id])

  @@index([applicationId])
  @@index([actorUserId])
  @@map("status_history")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorUserId Int
  action    String   @db.VarChar(100)
  entityType String? @db.VarChar(50)
  entityId  String?  @db.VarChar(50)
  metaJson  String?  @db.Text
  createdAt DateTime @default(now())

  actorUser User @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([action])
  @@map("audit_logs")
}

model Teacher {
  id                    Int       @id @default(autoincrement())
  instituteId           Int
  fullName              String    @db.VarChar(150)
  dob                   DateTime?
  gender                String?   @db.VarChar(20)
  nationality           String?   @db.VarChar(100)
  governmentId          String?   @db.VarChar(20)
  casterCategory        String?   @db.VarChar(50)

  qualification         String?   @db.VarChar(255)
  subjectSpecialization String?   @db.VarChar(150)
  certifications        String?   @db.Text
  certificates          String?   @db.Text

  designation           String?   @db.VarChar(100)
  serviceStartDate      DateTime?
  appointmentDate       DateTime?
  leavingDate           DateTime?
  leavingNote           String?   @db.Text
  teacherType           String?   @db.VarChar(50)
  employeeId            String?   @db.VarChar(80)
  payScale              String?   @db.VarChar(80)
  salary                Float?

  previousExperience    String?   @db.Text
  totalYearsService     Float?
  promotionsTransfers   String?   @db.Text

  trainingPrograms      String?   @db.Text
  workshops             String?   @db.Text
  ictCertification      String?   @db.Text

  appendixIxPublished   Boolean   @default(false)
  disclosureNotes       String?   @db.Text

  active      Boolean   @default(true)
  email       String?    @db.VarChar(150)
  mobile      String?    @db.VarChar(15)
  createdAt   DateTime   @default(now())

  institute Institute @relation(fields: [instituteId], references: [id])

  @@index([instituteId])
  @@index([governmentId])
  @@index([teacherType])
  @@map("teachers")
}

model InstituteStreamSubject {
  id                 Int      @id @default(autoincrement())
  instituteId        Int
  streamId           Int
  subjectId          Int
  answerLanguageCode String?  @db.VarChar(10)
  createdAt          DateTime @default(now())

  institute Institute @relation(fields: [instituteId], references: [id])
  stream    Stream    @relation(fields: [streamId], references: [id])
  subject   Subject   @relation(fields: [subjectId], references: [id])

  @@unique([instituteId, streamId, subjectId])
  @@index([instituteId])
  @@index([streamId])
  @@index([subjectId])
  @@map("institute_stream_subjects")
}

model StreamSubject {
  id        Int      @id @default(autoincrement())
  streamId  Int
  subjectId Int
  createdAt DateTime @default(now())

  stream  Stream  @relation(fields: [streamId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([streamId, subjectId])
  @@index([streamId])
  @@map("stream_subjects")
}

model News {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  content   String   @db.Text
  type      String   @db.VarChar(50) // news, notification, event
  isActive  Boolean  @default(true)
  createdByUserId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User @relation("NewsCreatedBy", fields: [createdByUserId], references: [id])

  @@index([isActive])
  @@index([createdAt])
  @@map("news")
}

model Statistic {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     Int      @default(0)
  description String? @db.VarChar(255)
  updatedAt DateTime @updatedAt

  @@map("statistics")
}

