# ═══════════════════════════════════════════════════════════════════════════
# HSC Exam Portal - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# 
# IMPORTANT: This file shows EXAMPLE values. 
# Do NOT commit .env file to git (it's in .gitignore)
# Set these variables in Hostinger cPanel > Environment Variables or via SSH
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (CRITICAL - Required for app to work)
# ───────────────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://u441114691_exam:YOUR_DB_PASSWORD@127.0.0.1:3306/u441114691_exam"

# ───────────────────────────────────────────────────────────────────────────
# JWT SECRETS (CRITICAL - Required for authentication)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ───────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="your_access_secret_key_here_min_6_chars"
JWT_REFRESH_SECRET="your_refresh_secret_key_here_min_6_chars"
ACCESS_TOKEN_TTL="60m"
REFRESH_TOKEN_TTL_DAYS="30"

# ───────────────────────────────────────────────────────────────────────────
# CORS CONFIGURATION (CRITICAL - Required for frontend to work)
# ───────────────────────────────────────────────────────────────────────────
CORS_ORIGIN="https://hsc-exam-form.hisofttechnology.com"

# ───────────────────────────────────────────────────────────────────────────
# APPLICATION URLs
# ───────────────────────────────────────────────────────────────────────────
BACKEND_URL="https://hsc-api.hisofttechnology.com"
FRONTEND_URL="https://hsc-exam-form.hisofttechnology.com"

# ───────────────────────────────────────────────────────────────────────────
# GOOGLE OAuth (Optional but recommended for Google Sign-In)
# Get your credentials from: https://console.cloud.google.com
# ───────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id_here.apps.googleusercontent.com"

# ───────────────────────────────────────────────────────────────────────────
# CASHFREE PAYMENT GATEWAY (Optional - only if you want payment feature)
# Sandbox credentials from: https://merchant.cashfree.com/merchants/login
# ───────────────────────────────────────────────────────────────────────────
# CASHFREE_APP_ID="your_cashfree_app_id_here"
# CASHFREE_SECRET_KEY="your_cashfree_secret_key_here"
# CASHFREE_WEBHOOK_SECRET="your_webhook_secret_here"
# EXAM_FEE_PAISE="50000"  # ₹500 in paise

# ───────────────────────────────────────────────────────────────────────────
# ENCRYPTION KEY (Optional - for sensitive field encryption)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ───────────────────────────────────────────────────────────────────────────
# ENCRYPTION_KEY="your_32_char_hex_key_for_aes256_encryption"

# ───────────────────────────────────────────────────────────────────────────
# NODE ENVIRONMENT (Should always be 'production' on Hostinger)
# ───────────────────────────────────────────────────────────────────────────
NODE_ENV="production"

# ───────────────────────────────────────────────────────────────────────────
# BUILD ID (For tracking deployments)
# ───────────────────────────────────────────────────────────────────────────
BUILD_ID="prod-2026-04-02"
