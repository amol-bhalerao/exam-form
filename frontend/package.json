{
  "name": "exam-form",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx ng serve --host 0.0.0.0 --port 4200",
    "build": "npx ng build --configuration production",
    "postbuild": "node -e \"const fs = require('fs'); const path = require('path'); const destDir = 'dist/exam-form/browser'; if (!fs.existsSync(destDir)) { fs.mkdirSync(destDir, { recursive: true }); } if (fs.existsSync('src/assets/.htaccess')) { fs.copyFileSync('src/assets/.htaccess', path.join(destDir, '.htaccess')); console.log('Copied .htaccess to dist'); } else { console.warn('Warning: src/assets/.htaccess not found'); }\"",
    "watch": "npx ng build --watch --configuration development",
    "test": "npx ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/material": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "ag-grid-angular": "^31.1.0",
    "ag-grid-community": "^31.3.4",
    "chart.js": "^4.5.1",
    "ng2-charts": "^4.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.2"
  }
}
