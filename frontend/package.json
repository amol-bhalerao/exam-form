{
  "name": "exam-form",
  "version": "0.0.0",
  "scripts": {
    "ng": "npx ng",
    "start": "node --max-old-space-size=4096 node_modules/@angular/cli/bin/ng.js serve --host 0.0.0.0 --port 4200",
    "build": "node --max-old-space-size=4096 node_modules/@angular/cli/bin/ng.js build --configuration production && npm run postbuild",
    "build:dev": "node --max-old-space-size=4096 node_modules/@angular/cli/bin/ng.js build && npm run postbuild",
    "postbuild": "node -e \"require('fs').copyFileSync('src/assets/.htaccess', 'dist/exam-form/browser/.htaccess')\"",
    "watch": "node --max-old-space-size=4096 node_modules/@angular/cli/bin/ng.js build --watch --configuration development",
    "test": "node --max-old-space-size=4096 node_modules/@angular/cli/bin/ng.js test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.2.7",
    "@angular/cdk": "^20.2.7",
    "@angular/common": "^20.2.7",
    "@angular/compiler": "^20.2.7",
    "@angular/core": "^20.2.7",
    "@angular/forms": "^20.2.7",
    "@angular/material": "^20.2.7",
    "@angular/platform-browser": "^20.2.7",
    "@angular/platform-browser-dynamic": "^20.2.7",
    "@angular/router": "^20.2.7",
    "ag-grid-angular": "^34.3.1",
    "ag-grid-community": "^34.3.1",
    "chart.js": "^4.5.1",
    "ng2-charts": "^4.1.1",
    "rxjs": "~7.8.0",
